// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../lib/prisma-client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Course {
  id          String   @id @default(cuid())
  title       String
  description String?
  price       Float    @default(0)
  image       String?
  level       String   @default("Grade 12")
  status      String   @default("Published")
  isFree      Boolean  @default(false)
  createdAt   DateTime @default(now())
  lessons     Lesson[]
}

model Lesson {
  id        String   @id @default(cuid())
  title     String
  videoUrl  String
  maxViews  Int      @default(3)
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id])
  createdAt DateTime @default(now())
  lessonProgresses LessonProgress[]
}

model ActivationCode {
  id        String   @id @default(cuid())
  code      String   @unique
  courseId  String
  course    String
  status    String   @default("Active") // Active, Used
  maxUses   Int      @default(1)
  usedCount Int      @default(0)
  usedBy    String   @default("[]") // JSON array of student IDs who used this code
  createdAt DateTime @default(now())
}

model Admin {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Student {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  phone     String?
  level     String   @default("Grade 12")
  unlockedCourses String @default("[]") // JSON array of course IDs
  createdAt DateTime @default(now())
  lessonProgresses LessonProgress[]
}

model Level {
  id    String @id @default(cuid())
  name  String @unique
}

model LessonProgress {
  id        String   @id @default(cuid())
  studentId String
  lessonId  String
  viewsUsed Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([studentId, lessonId])
}
